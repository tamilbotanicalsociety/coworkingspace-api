    {
      "name": "5. User View Own Booking",
      "description": "👀 ขั้นตอนที่ 5 — ดู Booking ที่สร้างไว้\n\nจุดประสงค์: ทดสอบว่า User ทั่วไปเห็นเฉพาะ Booking ของตัวเอง\n\nรายละเอียด:\n- GET /bookings — ดู Booking ทั้งหมดของ user (ต้องเห็น 3 รายการ)\n- GET /bookings/:id — ดูรายละเอียด Booking เฉพาะตัว",
      "item": [
        {
          "name": "5.1 Get My Bookings — See 3 bookings",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✅ 5.1 My Bookings — Status 200', function () {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "});",
                  "",
                  "pm.test('✅ 5.1 My Bookings — success true + count is 3', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "    pm.expect(json.count).to.eql(3);",
                  "    pm.expect(json.data).to.be.an('array');",
                  "    pm.expect(json.data.length).to.eql(3);",
                  "});",
                  "",
                  "pm.test('✅ 5.1 My Bookings — All bookings belong to me', function () {",
                  "    var json = pm.response.json();",
                  "    var userId = pm.environment.get('DEMO_USER_ID');",
                  "    json.data.forEach(function(booking) {",
